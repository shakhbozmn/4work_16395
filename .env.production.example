# ============================================================
# 4work — Production Environment Variables
# Copy this file: cp .env.production.example .env.production
# NEVER commit .env.production to version control
# ============================================================

# Django
DEBUG=False
SECRET_KEY=generate-a-strong-secret-key-with-openssl-rand-base64-50

# Database (PostgreSQL — use Docker service name as host)
DB_NAME=4work_db
DB_USER=4work_user
DB_PASSWORD=use-a-strong-random-password
DB_HOST=db
DB_PORT=5432

# Allowed Hosts (comma-separated — your domain/IP)
# localhost and 127.0.0.1 are always added automatically by settings.py
ALLOWED_HOSTS=dscc-shahbozms.polandcentral.cloudapp.azure.com

# Site
SITE_NAME=4work
SITE_URL=https://dscc-shahbozms.polandcentral.cloudapp.azure.com

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# CORS / CSRF (must include https:// prefix)
CORS_ALLOWED_ORIGINS=https://dscc-shahbozms.polandcentral.cloudapp.azure.com
CSRF_TRUSTED_ORIGINS=https://dscc-shahbozms.polandcentral.cloudapp.azure.com

# Docker Hub image name
DOCKERHUB_USERNAME=your-dockerhub-username
