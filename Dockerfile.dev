# Stage 1: Builder - Install dependencies only
FROM python:3.12-slim AS builder

WORKDIR /app

# Install build dependencies in a single layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy and install dependencies (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Stage 2: Development - Lightweight runtime
FROM python:3.12-slim AS development

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/opt/venv/bin:$PATH"

WORKDIR /app

# Install only runtime dependencies (cached layer)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment from builder (cached layer)
COPY --from=builder /opt/venv /opt/venv

# Note: Project files are mounted via docker-compose volume for hot reload
# Only create necessary directories
RUN mkdir -p staticfiles media

EXPOSE 8000

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
