[flake8]
max-line-length = 88
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .tox,
    .mypy_cache,
    .pytest_cache,
    migrations,
    node_modules,
    static,
    media
ignore = E203, E501, W503
per-file-ignores =
    __init__.py:F401
    settings.py:F401
    conftest.py:F401
    factories.py:F401
