# ============================================================
# 4work — Development Environment Variables
# Copy this file: cp .env.example .env
# ============================================================

# Django
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production

# Database (PostgreSQL)
DB_NAME=4work_db
DB_USER=4work_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Allowed Hosts (comma-separated, required in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Site
SITE_NAME=4work
SITE_URL=http://localhost:8000

# Email (console backend used in dev when DEBUG=True)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# CORS / CSRF (comma-separated origins, only needed in production)
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Docker Hub (only needed for CI/CD and production docker-compose)
DOCKERHUB_USERNAME=your-dockerhub-username
